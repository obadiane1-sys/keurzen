{
  "expo": {
    "name": "Keurzen",
    "slug": "keurzen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "keurzen",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F9FC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.keurzen.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Permet d'ajouter une photo de profil.",
        "NSCameraUsageDescription": "Permet de prendre une photo de profil.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.keurzen.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F9FC"
      },
      "permissions": [
        "android.permission.NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#88D4A9",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permet d'ajouter une photo de profil.",
          "cameraPermission": "Permet de prendre une photo de profil."
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "34ff1e19-66cf-4931-b529-04a7eb5ee1a8"
      }
    }
  }
}
