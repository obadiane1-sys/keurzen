{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*)",
      "Read(**/credentials*)",
      "Read(**/secrets*)",
      "Write(**/credentials*)",
      "Write(**/secrets*)"
    ],
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "mcp__claude_ai_Supabase__*"
    ]
  },
  "env": {
    "ESLINT_USE_FLAT_CONFIG": "false"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "timeout": 60,
            "statusMessage": "Lint en cours…",
            "command": "/Users/ouss/Keurzen/.claude/lint-hook.sh"
          }
        ]
      }
    ]
  }
}
